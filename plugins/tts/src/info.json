            "identifier": "apiKey",
            "type": "text",
            "title": "API Key",
            "desc": "必填。DashScope API Key，可在 https://dashscope.console.aliyun.com/ 申请",
            "textConfig": {
                "type": "secure",
                "height": 40,
                "placeholderText": "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
            }
        },
        {
            "identifier": "region",
            "type": "menu",
            "title": "API 地域",
            "defaultValue": "cn",
            "desc": "国内用户选北京，海外用户选新加坡",
            "menuValues": [
                { "title": "北京 (国内)", "value": "cn" },
                { "title": "新加坡 (国际)", "value": "intl" }
            ]
        },
        {
            "identifier": "model",
            "type": "menu",
            "title": "模型",
            "defaultValue": "qwen3-tts-instruct-flash",
            "desc": "Instruct-Flash 支持指令控制语速/情感，Flash 速度最快",
            "menuValues": [
                { "title": "Qwen3-TTS-Instruct-Flash (推荐)", "value": "qwen3-tts-instruct-flash" },
                { "title": "Qwen3-TTS-Flash", "value": "qwen3-tts-flash" },
                { "title": "自定义模型", "value": "custom" }
