        {
            "identifier": "instructions",
            "type": "text",
            "title": "语音指令 (Instruct 模型专属)",
            "defaultValue": "",
            "desc": "用自然语言描述语音风格，如「语速较快，带有上扬语调，适合介绍时尚产品」。仅 Instruct-Flash 模型生效",
            "textConfig": {
                "type": "visible",
                "height": 80,
                "placeholderText": "例: 语速偏慢，音调温柔甜美，语气治愈温暖"
            }
        },
        {
            "identifier": "optimizeInstructions",
            "type": "menu",
            "title": "指令语义增强",
            "defaultValue": "false",
            "desc": "开启后系统会对语音指令进行语义增强重写，可能提升效果。仅 Instruct-Flash 模型生效",
            "menuValues": [
                { "title": "关闭", "value": "false" },
                { "title": "开启", "value": "true" }
            ]
        },
        {
            "identifier": "timeout",
            "type": "text",
            "title": "超时时间 (秒)",
            "defaultValue": "60",
            "desc": "语音合成超时时间，范围 30-300 秒",
            "textConfig": {
                "type": "visible",
                "placeholderText": "60"
