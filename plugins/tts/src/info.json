        {
            "identifier": "languageType",
            "type": "menu",
            "title": "合成语种",
            "defaultValue": "Auto",
            "desc": "指定语种可显著提升合成质量。Auto 自动检测适合多语种混合文本",
            "menuValues": [
                { "title": "自动检测", "value": "Auto" },
                { "title": "中文", "value": "Chinese" },
                { "title": "英语", "value": "English" },
                { "title": "日语", "value": "Japanese" },
                { "title": "韩语", "value": "Korean" },
